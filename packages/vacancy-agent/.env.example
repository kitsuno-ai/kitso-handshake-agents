# Vacancy Agent — environment configuration
#
# Copy this file to .env and fill in real values. Never commit .env to source.

# === Required for live mode (set both, or only run with --dry-run) ===

# Moltbook API key (Bearer token). Get from the venue after agent registration + X claim.
MOLTBOOK_API_KEY=

# Random token used to authenticate /kill requests. Store somewhere you can reach
# under pressure (a phone-accessible notes app, NOT this repo).
AGENT_KILL_TOKEN=

# === Optional ===

# Postgres URL for the audit DB. If unset, audit events go to stdout/stderr.
# Use an ISOLATED database — never a shared production credential.
# AUDIT_DB_URL=postgres://...

# Where the vacancy card JSON files are hosted. Used to build the agent-facing
# link inside the post body. Default: https://kitsuno.ai/handshake/v0.1/vacancies/
# CARD_HOST_BASE=https://kitsuno.ai/handshake/v0.1/vacancies/

# Where the human-readable JD pages are hosted. Used to build the human-facing
# link inside the post body. Default: https://kitsuno.ai/jobs/
# JD_HOST_BASE=https://kitsuno.ai/jobs/

# Agent identity declared in the audit log and User-Agent. Defaults are sane;
# change only if you're forking under a different identity.
# AGENT_DNS=kitsuno.agent
# AGENT_HANDLE=kitsuno_jobs

# AUP: minimum seconds between posts on the same agent. Moltbook enforces 30 min.
# DO NOT lower this in a fork without explicit venue permission.
# RATE_LIMIT_SECONDS_BETWEEN_POSTS=1800
